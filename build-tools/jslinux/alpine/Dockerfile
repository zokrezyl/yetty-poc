FROM alpine:3.23
RUN apk add --no-cache \
    # Shells
    bash \
    zsh \
    # Core utilities
    coreutils \
    findutils \
    grep \
    sed \
    gawk \
    diffutils \
    patch \
    less \
    file \
    util-linux \
    # Build tools (build-base = gcc, g++, make, libc-dev)
    build-base \
    cmake \
    binutils \
    musl-dev \
    linux-headers \
    # Editors
    neovim \
    # Version control
    git \
    # Python
    python3 \
    py3-pip \
    # Network tools
    curl \
    wget \
    # Compression
    tar \
    gzip \
    xz \
    zip \
    unzip \
    # Documentation
    man-pages \
    mandoc \
    # Debug tools
    strace \
    # Terminal
    ncurses-terminfo-base \
    # Misc
    tree \
    htop
