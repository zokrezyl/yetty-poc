#!/bin/bash
# LibWeb to YDraw pipeline wrapper
set -e
HTML_TO_DISPLAYLIST="@CMAKE_CURRENT_BINARY_DIR@/html-to-displaylist"
DISPLAYLIST_TO_YDRAW="@CMAKE_CURRENT_BINARY_DIR@/displaylist-to-ydraw"
if [ -z "$1" ]; then
    echo "Usage: $0 <html-file-or-url>" >&2
    exit 1
fi
"$HTML_TO_DISPLAYLIST" "$1" | "$DISPLAYLIST_TO_YDRAW"
